module Raiha
  module Qlog
    class Event
      NAMESPACE: String

      attr_reader time: Time
      attr_reader event_type: Symbol
      attr_reader data: Hash[Symbol, untyped]

      def initialize: (event_type: Symbol, ?data: Hash[Symbol, untyped]) -> void
      def to_h: -> Hash[Symbol, untyped]
      def to_json: (*untyped args) -> String
    end

    module ConnectionEvents
      class ConnectionStarted < Event
        def initialize: (src_cid: String, dest_cid: String) -> void
      end

      class ConnectionStateUpdated < Event
        def initialize: (old_state: Symbol, new_state: Symbol) -> void
      end

      class ConnectionClosed < Event
        def initialize: (owner: Symbol, trigger: Symbol, ?error_code: Integer?, ?reason: String?) -> void
      end

      class ConnectionIdUpdated < Event
        def initialize: (owner: Symbol, old_id: String, new_id: String) -> void
      end
    end

    module TransportEvents
      class PacketSent < Event
        def initialize: (packet_type: (Symbol | String), packet_number: Integer, ?frames: Array[untyped]) -> void
      end

      class PacketReceived < Event
        def initialize: (packet_type: (Symbol | String), packet_number: Integer, ?frames: Array[untyped]) -> void
      end

      class PacketDropped < Event
        def initialize: (?packet_type: (Symbol | String)?, ?trigger: (Symbol | String)?) -> void
      end

      class ParametersSet < Event
        def initialize: (initiator: Symbol, parameters: Hash[Symbol, untyped]) -> void
      end

      class StreamStateUpdated < Event
        def initialize: (stream_id: Integer, stream_type: Symbol, ?old_state: Symbol?, new_state: Symbol) -> void
      end
    end

    module SecurityEvents
      class KeyUpdated < Event
        def initialize: (key_type: Symbol, ?generation: Integer?, ?trigger: Symbol?) -> void
      end

      class KeyDiscarded < Event
        def initialize: (key_type: Symbol, ?generation: Integer?, ?trigger: Symbol?) -> void
      end
    end

    module RecoveryEvents
      class RecoveryMetricsUpdated < Event
        def initialize: (?min_rtt: Numeric?, ?smoothed_rtt: Numeric?, ?latest_rtt: Numeric?, ?rtt_variance: Numeric?, ?pto_count: Integer?, ?congestion_window: Integer?, ?bytes_in_flight: Integer?, ?ssthresh: Integer?, ?packets_in_flight: Integer?, ?pacing_rate: Integer?) -> void
      end

      class CongestionStateUpdated < Event
        def initialize: (?old_state: Symbol?, new_state: Symbol) -> void
      end

      class PacketLost < Event
        def initialize: (packet_type: (Symbol | String), packet_number: Integer, ?trigger: Symbol?) -> void
      end
    end

    module FrameSerializer
      def self.to_h: (untyped frame) -> Hash[Symbol, untyped]
      def self.compute_acked_ranges: (untyped frame) -> Array[[Integer, Integer]]?
    end
  end
end
