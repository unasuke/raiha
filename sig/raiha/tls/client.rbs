module Raiha
  module TLS
    class Client < Peer
      module State
        START: :START
        WAIT_SH: :WAIT_SH
        WAIT_EE: :WAIT_EE
        WAIT_CERT_CR: :WAIT_CERT_CR
        WAIT_CERT: :WAIT_CERT
        WAIT_CV: :WAIT_CV
        WAIT_FINISHED: :WAIT_FINISHED
        WAIT_SEND_FINISHED: :WAIT_SEND_FINISHED
        CONNECTED: :CONNECTED
        WAIT_SH_RETRY: :WAIT_SH_RETRY
        ERROR: :ERROR
        CLOSED: :CLOSED
      end

      @state: Symbol
      @buffer: Array[String]
      @receive_buffer: String
      @supported_groups: Array[untyped]
      @transcript_hash: TranscriptHash
      @received: Array[Record::TLSPlaintext | Record::TLSCiphertext]
      @close_notify_sent: bool
      @client_auth_required: bool
      @certificate_request: Handshake::CertificateRequest?

      attr_reader state: Symbol
      attr_reader key_schedule: KeySchedule
      attr_reader server_hello: Handshake::ServerHello?
      attr_reader transcript_hash: TranscriptHash
      attr_reader encrypted_extensions: Handshake::EncryptedExtensions?
      attr_accessor additional_extensions: Array[Handshake::Extension::AbstractExtension]

      def initialize: (?config: Config?, ?server_name: String?) -> void
      def build_client_hello: -> Array[String]
      def build_client_finished_handshake: -> Handshake?
      def datagrams_to_send: -> Array[String]?
      def receive: (String datagram) -> String
      def finished?: -> bool
      def handle_handshake_message: (Handshake handshake) -> void
      def handle_alert_message: (Alert alert) -> void
      def handle_application_data_message: (ApplicationData data) -> String
      def receive_server_hello: (Handshake handshake) -> void
      def receive_hello_retry_request: (Handshake handshake) -> void
      def receive_encrypted_extensions: (Handshake handshake) -> void
      def receive_certificate_or_certificate_request: (Handshake handshake) -> void
      def receive_certificate_verify: (Handshake handshake) -> void
      def receive_finished: (Handshake handshake) -> void
      def receive_new_session_ticket: (Handshake handshake) -> void
      def receive_key_update: (Handshake handshake) -> void
      def send_early_data: (String data) -> String?
      def send_end_of_early_data: -> String?
      def send_key_update: (?request_update: Symbol) -> Array[String]
      def send_alert: (Symbol level, Symbol description) -> Array[String]
      def receive_anything_else: (Handshake handshake) -> void
      def respond_to_finished: -> Array[String]

      private def setup_early_data_cipher: (untyped psk_entry) -> void
      private def add_psk_to_client_hello: (Handshake hs_clienthello, untyped psk_entry) -> void
      private def compute_psk_binder: (String psk, String truncated_client_hello, String hash_alg) -> String
      private def generate_pkey: (String group) -> (OpenSSL::PKey::PKey | OpenSSL::PKey::EC)
      private def rebuild_client_hello_for_retry: (Handshake::ServerHello hrr, requested_group: String?) -> void
      private def transition_state: (Symbol state) -> void
      private def valid_server_hello?: -> bool
      private def setup_key_schedule: -> void
      private def verify_certificate_verify: (Handshake certificate_verify) -> void
      private def verify_finished: (Handshake finished) -> void
      private def handle_plaintext_record: (Record::TLSPlaintext record) -> Array[Handshake | Alert | ApplicationData]
      private def handle_ciphertext_record: (Record::TLSCiphertext record) -> Array[Handshake | Alert | ApplicationData]
      private def send_client_certificate: -> Array[String]
      private def save_to_sslkeylogfile: -> void
    end
  end
end
