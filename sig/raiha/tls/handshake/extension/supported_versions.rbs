module Raiha
  module TLS
    class Handshake
      class Extension
        class SupportedVersions < AbstractExtension
          EXTENSION_TYPE_NUMBER: 43
          @protocol_versions: Array[String]

          def self.generate_for_tls13: (?on: :client_hello | :server_hello | :hello_retry_request | :encrypted_extensions | :certificate | :certificate_request | :new_session_ticket) -> SupportedVersions
        end
      end
    end
  end
end
